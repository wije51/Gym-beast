# API Configuration
VITE_API_BASE_URL=https://api.gymbeast.example
VITE_API_TIMEOUT=30000

# Contact Information
VITE_CONTACT_EMAIL=hello@gymbeast.example
VITE_SUPPORT_EMAIL=support@gymbeast.example

# Analytics (optional)
VITE_GA_ID=

# File Upload Settings (if implemented)
VITE_MAX_UPLOAD_SIZE=10485760
VITE_UPLOAD_ENDPOINT=https://api.gymbeast.example/upload

# AWS S3 (if using cloud storage)
VITE_AWS_REGION=us-east-1
VITE_AWS_BUCKET=gym-beast-uploads

# Security
VITE_ENABLE_SECURITY_HEADERS=true
VITE_ENABLE_CORS=false
